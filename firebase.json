{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "package.json",
      "package-lock.json",
      "README.md",
      ".git/**",
      ".github/**",
      ".gitignore",
      ".firebase/**",
      "node_modules/**",
      ".idea/**",
      ".vscode/**"
    ],
    "rewrites": [
      { "source": "/", "destination": "/src/index.html" },
      { "source": "/games/:game", "destination": "/src/games/:game/index.html" },
      { "source": "/games/:game/", "destination": "/src/games/:game/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(css|js|svg|jpg|jpeg|png|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  }
}
