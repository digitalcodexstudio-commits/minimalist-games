{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/src/index.html" },
    { "source": "/games/:game", "destination": "/src/games/:game/index.html" },
    { "source": "/games/:game/", "destination": "/src/games/:game/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(css|js|svg|jpg|png|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
